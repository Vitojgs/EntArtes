<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36" version="29.6.1" pages="5">
  <diagram name="DS - Pedido Aula" id="QsG8X0dwc7yMa9GrWGkN">
    <mxGraphModel dx="1727" dy="1023" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="dwkEObJwb1v6Doou0AIS-0" />
        <mxCell id="dwkEObJwb1v6Doou0AIS-1" parent="dwkEObJwb1v6Doou0AIS-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Diagrama de Sequência - Pedido de Aula\n\nactor EncarregadoEducacao as EE\nactor Direcao\nactor Professor\n\nboundary PaginaPedidoAulaUI as UI\ncontrol Controlador\n\nparticipant PedidoDeAula\nparticipant Aula\nparticipant Estado\nparticipant AlunoPedidoAula\nparticipant AlunoAula\nparticipant Sala\nparticipant Disponibilidade\n\n== Submissão do pedido ==\n\nEE -&gt; UI : preencher dados do pedido\nactivate UI\n\nEE -&gt; UI : submeterPedidoAula()\nUI -&gt; Controlador: submeterPedidoAula(dadosPedido)\nactivate Controlador\n\nControlador-&gt; Disponibilidade : consultarDisponibilidade(idDisponibilidade)\nactivate Disponibilidade\nDisponibilidade --&gt; Controlador : dadosDisponibilidade\ndeactivate Disponibilidade\n\nControlador -&gt; Sala : consultarSalaDisponivel(data,hora,duracao)\nactivate Sala\nSala --&gt; Controlador : salaDisponivel\ndeactivate Sala\n\nControlador -&gt; PedidoDeAula : registarPedido(dadosPedido, estado=\&quot;Aguardar\&quot;)\nactivate PedidoDeAula\nPedidoDeAula --&gt; Controlador : pedidoRegistado(idPedido)\ndeactivate PedidoDeAula\n\nControlador --&gt; UI : pedidoSubmetido()\n \nUI --&gt; EE : pedido submetido com sucesso\ndeactivate UI\n\n== Direção recebe e avalia ==\n\nControlador -&gt; UI : notificarPedidoPendente()\ndeactivate Controlador\nactivate UI\nUI --&gt; Direcao : receberPedido()\ndeactivate UI\n\nDirecao -&gt; UI : avaliarPedido(decisao)\nactivate UI\nUI -&gt; Controlador : avaliarPedido(idPedido, decisao)\nactivate Controlador\n\nalt pedido aprovado\n\n    Controlador -&gt; Estado : atualizarEstadoPedido(idPedido, \&quot;Aprovado\&quot;)\n    activate Estado\n    Estado --&gt; Controlador : estadoAtualizado\n    deactivate Estado\n\n    Controlador -&gt; Aula : criarAula(idPedido, idSala, estado=\&quot;Por Realizar\&quot;)\n    activate Aula\n    Aula --&gt; Controlador : aulaCriada(idAula)\n    deactivate Aula\n\n    opt existem alunos associados ao pedido\n        Controlador -&gt; AlunoPedidoAula : obterAlunosDoPedido(idPedido)\n        activate AlunoPedidoAula\n        AlunoPedidoAula --&gt; Controlador : listaAlunos\n        deactivate AlunoPedidoAula\n\n        loop para cada aluno\n            Controlador -&gt; AlunoAula : associarAlunoAula(idAluno, idAula)\n            activate AlunoAula\n            AlunoAula --&gt; Controlador : associacaoCriada\n            deactivate AlunoAula\n        end\n    end\n\n    Controlador --&gt; UI : notificarAceitacao(dadosAula)\n    deactivate Controlador\n    UI --&gt; EE : receber notificação de nova aula marcada\n    UI --&gt; Professor : receber notificação de nova aula marcada\n    \nelse pedido recusado\n\n\n    Controlador -&gt; Estado : atualizarEstadoPedido(idPedido, \&quot;Recusado\&quot;)\n    activate Controlador\n    activate Estado\n    Estado --&gt; Controlador : estadoAtualizado\n    deactivate Estado\n    deactivate Controlador\n\n    Controlador --&gt; UI : notificarRejeicao()\n    deactivate Controlador\n    UI --&gt; EE : receber notificação da rejeição\n    deactivate UI\n\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="dwkEObJwb1v6Doou0AIS-2">
          <mxCell parent="dwkEObJwb1v6Doou0AIS-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1240" width="1698" x="160" y="240" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="DS - Marcar Aula" id="QJ-B5NJXKSldvVl4lwAE">
    <mxGraphModel dx="1554" dy="921" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="eFpb5SMkfsi-wef2Ngqy-0" />
        <mxCell id="eFpb5SMkfsi-wef2Ngqy-1" parent="eFpb5SMkfsi-wef2Ngqy-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Diagrama de Sequência - Marcar Aula\n\nactor EncarregadoEducacao as EE\n\nboundary PaginaMarcacaoUI as UI\ncontrol Controlador\n\nparticipant PedidoDeAula\nparticipant Aula\nparticipant AlunoPedidoAula\nparticipant AlunoAula\n\nEE -&gt; UI : marcar aula\nactivate UI\n\nUI -&gt; Controlador : marcarAula(idAluno, idPedido)\nactivate Controlador\n\nControlador -&gt; PedidoDeAula : obterPedido(idPedido)\nactivate PedidoDeAula\nPedidoDeAula --&gt; Controlador : pedido(estado, idPedido)\ndeactivate PedidoDeAula\n\nalt Estado : Aguardar\n    Controlador -&gt; AlunoPedidoAula : inserir(idAluno, idPedido)\n    activate AlunoPedidoAula\n    AlunoPedidoAula --&gt; Controlador : bool(true)\n    deactivate AlunoPedidoAula\n\n    Controlador --&gt; UI : marcação pendente\n    deactivate Controlador\n    UI --&gt; EE : aluno associado ao pedido\n    \nelse Estado : Aprovado\n    Controlador -&gt; Aula : obterAuladoPedido(idPedido)\n    activate Controlador\n    activate Aula\n    Aula --&gt; Controlador : aula(idAula)\n    deactivate Aula\n    deactivate Controlador\n\n    Controlador -&gt; AlunoAula : inserir(idAluno, idAula)\n    activate AlunoAula\n    activate Controlador\n    AlunoAula --&gt; Controlador : bool(true)\n    deactivate AlunoAula\n    \n\n    Controlador --&gt; UI : marcação confirmada\n    deactivate Controlador\n    UI --&gt; EE : aluno associado à aula\n    deactivate UI\n\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="Ds31pvurFpna14E-9Zdf-0">
          <mxCell parent="eFpb5SMkfsi-wef2Ngqy-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="649" width="1022" x="200" y="400" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="DS - Criar Anúncio" id="sOand6-EajUmcRkQ-Leh">
    <mxGraphModel dx="727" dy="921" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="f4OiOqHKkZ-jUIh2MBrv-0" />
        <mxCell id="f4OiOqHKkZ-jUIh2MBrv-1" parent="f4OiOqHKkZ-jUIh2MBrv-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Diagrama de Sequência - Criar Anúncio\n\nactor \&quot;Encarregado (Vendedor)\&quot; as Vendedor\nactor Direcao\n\nboundary PaginaCriarAnuncioUI as UI\ncontrol Controlador \n\nparticipant Figurino\nparticipant Anuncio\nparticipant Estado\n\nVendedor -&gt; UI : iniciar criação de anúncio\nactivate UI\n\n\n    Vendedor -&gt; UI : selecionar figurino\n    UI -&gt; Controlador : selecionarFigurino(idFigurino)\n    activate Controlador \n    Controlador -&gt; Figurino : consultarFigurino(idFigurino)\n    activate Figurino\n    Figurino --&gt; Controlador : dadosFigurino\n    deactivate Figurino\n    Controlador --&gt; UI : figurino selecionado\n    deactivate Controlador \n\n\nVendedor -&gt; UI : preencher dados do anúncio\nUI -&gt; Controlador : submeterAnuncio(dadosAnuncio, idFigurino)\nactivate Controlador \n\nControlador -&gt; Anuncio : registarAnuncio(dadosAnuncio, idFigurino)\nactivate Anuncio\nAnuncio --&gt; Controlador : anuncioRegistado(idAnuncio)\ndeactivate Anuncio\n\nControlador -&gt; Estado : definirEstado(idAnuncio, \&quot;Aguardar\&quot;)\nactivate Estado\nEstado --&gt; Controlador : estadoAtualizado\ndeactivate Estado\n\nControlador --&gt; UI : anuncioSubmetido()\ndeactivate Controlador \nUI --&gt; Vendedor : submissão concluída\ndeactivate UI\n\nDirecao -&gt; UI : avaliarAnuncio(idAnuncio, decisao)\nactivate UI\nUI -&gt; Controlador : avaliarAnuncio(idAnuncio, decisao)\nactivate Controlador \n\nalt aprovado\n    Controlador -&gt; Estado : definirEstadoAnuncio(idAnuncio, \&quot;Aprovado\&quot;)\n    activate Estado\n    Estado --&gt; Controlador : estadoAtualizado\n    deactivate Estado\n\n    Controlador --&gt; UI : notificarAprovacao()\n    deactivate Controlador \n    UI --&gt; Vendedor : receber notificação da aprovação\n    \n\nelse rejeitado\n    Controlador -&gt; Estado : definirEstado(idAnuncio, \&quot;Recusado\&quot;)\n    activate Controlador\n    activate Estado\n    Estado --&gt; Controlador : estadoAtualizado\n    deactivate Estado\n    \n\n    Controlador --&gt; UI : notificarRejeicao()\n    deactivate Controlador \n    UI --&gt; Vendedor : receber notificação da rejeição\n    deactivate UI\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="UQeba2tkUkWgo9WaXxU4-0">
          <mxCell parent="f4OiOqHKkZ-jUIh2MBrv-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="929" width="1168" x="1150" y="280" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="DS - Aluguer de Figurino" id="KyBKFKJIaD9Ou_Zmjhw-">
    <mxGraphModel dx="1554" dy="921" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="GGWRErynrS4vftHuKRii-0" />
        <mxCell id="GGWRErynrS4vftHuKRii-1" parent="GGWRErynrS4vftHuKRii-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Diagrama de Sequência - Alugar Figurino / Pedido de Reserva\n\nactor \&quot;Encarregado/Professor\&quot; as Utilizador\nactor Direcao\n\nboundary PaginaReservaUI as UI\ncontrol Controlador \n\nparticipant Anuncio\nparticipant TransacaoFigurino\nparticipant Estado\n\n== Selecionar anúncio ==\n\nUtilizador -&gt; UI : selecionarAnuncio(idAnuncio)\nactivate UI\nUI -&gt; Controlador : selecionarAnuncio(idAnuncio)\nactivate Controlador \n\nControlador -&gt; Anuncio : consultarAnuncio(idAnuncio)\nactivate Anuncio\nAnuncio --&gt; Controlador : dadosAnuncio\ndeactivate Anuncio\n\nControlador --&gt; UI : dadosAnuncio\ndeactivate Controlador \n\n== Fazer pedido de reserva ==\n\nUtilizador -&gt; UI : fazerPedidoReserva(dadosReserva)\nUI -&gt; Controlador  : submeterPedidoReserva(dadosReserva)\nactivate Controlador \n\nControlador -&gt; TransacaoFigurino : registarTransacao(dadosReserva)\nactivate TransacaoFigurino\nTransacaoFigurino --&gt; Controlador : pedidoRegistado(idTransacao)\ndeactivate TransacaoFigurino\n\nControlador -&gt; Estado : definirEstadoTransacao(idTransacao, \&quot;Aguardar\&quot;)\nactivate Estado\nEstado --&gt; Controlador : estadoAtualizado\ndeactivate Estado\n\nControlador --&gt; UI : pedidoSubmetido()\ndeactivate Controlador \nUI --&gt; Utilizador : pedido de reserva submetido\ndeactivate UI\n\n== Direção avalia pedido ==\n\nDirecao -&gt; UI : receberPedidoReserva(idTransacao)\nactivate UI\nUI -&gt; Controlador : avaliarPedidoReserva(idTransacao, decisao)\nactivate Controlador \n\nalt pedido aprovado\n\n    Controlador -&gt; Estado : definirEstadoTransacao(idTransacao, \&quot;Aceite\&quot;)\n    activate Estado\n    Estado --&gt; Controlador : estadoAtualizado\n    deactivate Estado\n\n    Controlador  --&gt; UI : notificarAceitacaoPedido()\n    deactivate Controlador \n    UI --&gt; Utilizador : receber notificação de aceitação\n    deactivate UI\n\n    alt utilizador aceita reserva\n        Utilizador -&gt; UI : confirmarReserva()\n        activate UI\n        UI -&gt; Controlador : confirmarReserva(idTransacao)\n        activate Controlador \n\n        Controlador -&gt; Estado : definirEstadoTransacao(idTransacao, \&quot;Confirmada\&quot;)\n        activate Estado\n        Estado --&gt; Controlador : estadoAtualizado\n        deactivate Estado\n\n        Controlador --&gt; UI : reservaConfirmada()\n        deactivate Controlador \n        UI --&gt; Utilizador : reserva aceite\n        deactivate UI\n\n    else utilizador cancela reserva\n        Utilizador -&gt; UI : cancelarReserva()\n        activate UI\n        UI -&gt; Controlador : cancelarReserva(idTransacao)\n        activate Controlador \n\n        Controlador -&gt; Estado : definirEstadoTransacao(idTransacao, \&quot;Cancelada\&quot;)\n        activate Estado\n        Estado --&gt; Controlador : estadoAtualizado\n        deactivate Estado\n\n        Controlador --&gt; UI : reservaCancelada()\n        deactivate Controlador \n        UI --&gt; Utilizador : reserva cancelada\n        deactivate UI\n    end\n\nelse pedido recusado\n\n    Controlador -&gt; Estado : definirEstadoTransacao(idTransacao, \&quot;Recusado\&quot;)\n    activate Estado\n    activate Controlador\n    Estado --&gt; Controlador : estadoAtualizado\n    deactivate Estado\n\n    Controlador --&gt; UI : notificarRejeicaoPedido()\n    deactivate Controlador \n    UI --&gt; Utilizador : receber notificação de rejeição\n    deactivate UI\n\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="hImL_5pU1cWvq0GXRt1l-0">
          <mxCell parent="GGWRErynrS4vftHuKRii-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1405" width="1243" x="440" y="180" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="DS - Cancelar/Remarcar Aula" id="Ae9KynQivMsKZnyRiJOi">
    <mxGraphModel dx="1554" dy="921" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="8z9moSxefHLAhlpzRJIM-0" />
        <mxCell id="8z9moSxefHLAhlpzRJIM-1" parent="8z9moSxefHLAhlpzRJIM-0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Diagrama de Sequência - Cancelar e Remarcar Aula\n\nactor Professor\nactor Direcao\nactor EncarregadoEducacao as EE\n\nboundary PaginaAulaUI as UI\ncontrol Controlador \n\nparticipant Aula\nparticipant Disponibilidade\nparticipant Sala\nparticipant  EstadoAula\n\n== Cancelamento da aula ==\n\nProfessor -&gt; UI : cancelarAula(idAula, motivo)\nactivate UI\nUI -&gt; Controlador : cancelarAula(idAula, motivo)\nactivate Controlador \n\nControlador -&gt; Aula : consultarAula(idAula)\nactivate Aula\nAula --&gt; Controlador : dadosAula\ndeactivate Aula\n\nControlador --&gt; UI : pedidoCancelamentoRecebido()\ndeactivate Controlador \nUI --&gt; Direcao : receberPedidoCancelarAula()\ndeactivate UI\n\n== Remarcação pela Direção ==\n\nDirecao -&gt; UI : remarcarAula(idAula)\nactivate UI\nUI -&gt; Controlador : remarcarAula(idAula)\nactivate Controlador \n\nControlador -&gt; Disponibilidade : verificarDisponibilidadeProfessor(idProfessor, novaData)\nactivate Disponibilidade\nDisponibilidade --&gt; Controlador : disponibilidadeProfessor\ndeactivate Disponibilidade\n\nalt professor sem disponibilidade\n\n    Controlador -&gt; EstadoAula : definirEstado(idAula, \&quot;Cancelada\&quot;)\n    activate EstadoAula\n    EstadoAula --&gt; Controlador : estadoAtualizado\n    deactivate EstadoAula\n\n    Controlador --&gt; UI : notificarCancelamento()\n     \n    UI --&gt; Professor : receber notificação de cancelamento\n    UI --&gt; EE : receber notificação de cancelamento\n    deactivate UI\n\nelse professor com disponibilidade\n\n    Controlador -&gt; Sala : ConsultarSalaDisponivel(novaData, hora, duracao)\n    activate Sala\n    Sala --&gt; Controlador : salaDisponivel\n    deactivate Sala\n\n    alt sala indisponível\n\n        Controlador -&gt; EstadoAula : definirEstado(idAula, \&quot;Cancelada\&quot;)\n        activate EstadoAula\n        EstadoAula --&gt; Controlador : estadoAtualizado\n        deactivate EstadoAula\n\n        Controlador --&gt; UI : notificarCancelamento()\n         \n        UI --&gt; Professor : receber notificação de cancelamento\n        UI --&gt; EE : receber notificação de cancelamento\n        deactivate UI\n\n\n    else sala disponível\n\n        Controlador --&gt; UI : enviarNovaDataParaEE(novaData, hora)\n        deactivate Controlador \n        UI --&gt; EE : receber pedido de nova data\n        deactivate UI\n\n        alt EE aceita nova data\n\n            EE -&gt; UI : aceitarNovaData(idAula, novaData)\n            activate UI\n            UI -&gt; Controlador : confirmarRemarcacao(idAula, novaData)\n            activate Controlador \n\n            Controlador -&gt; Aula : atualizarDataAula(idAula, novaData, hora, sala)\n            activate Aula\n            Aula --&gt; Controlador : aulaAtualizada\n            deactivate Aula\n\n            Controlador -&gt; EstadoAula : definirEstado(idAula, \&quot;Por Realizar\&quot;)\n            activate EstadoAula\n            EstadoAula --&gt; Controlador : estadoAtualizado\n            deactivate EstadoAula\n\n            Controlador --&gt; UI : notificarRemarcacao()\n            deactivate Controlador \n            UI --&gt; Professor : receber notificação de remarcação\n            UI --&gt; EE : receber notificação de remarcação\n            deactivate UI\n\n        else EE rejeita nova data\n\n            EE -&gt; UI : rejeitarNovaData(idAula)\n            activate UI\n            UI -&gt; Controlador : rejeitarRemarcacao(idAula)\n            activate Controlador \n\n            Controlador -&gt; EstadoAula : definirEstado(idAula, \&quot;Cancelada\&quot;)\n            activate EstadoAula\n            EstadoAula --&gt; Controlador : estadoAtualizado\n            deactivate EstadoAula\n\n            Controlador --&gt; UI : notificarCancelamento()\n            deactivate Controlador \n            UI --&gt; Professor : receber notificação de cancelamento\n            UI --&gt; EE : receber notificação de cancelamento\n            deactivate UI\n\n        end\n    end\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="-5F3paJHba4V7hNAyTPP-0">
          <mxCell parent="8z9moSxefHLAhlpzRJIM-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1546" width="1457" x="490" y="160" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
